# O Docker Compose le o .env automaticamente a partir da raiz do projeto.
# Copie este arquivo para .env e ajuste os valores do seu ambiente.

SPRING_PROFILES_ACTIVE=docker

SPRING_CASSANDRA_CONTACT_POINTS=cassandra
SPRING_CASSANDRA_PORT=9042
SPRING_CASSANDRA_KEYSPACE=hospital
SPRING_CASSANDRA_LOCAL_DATACENTER=dc1

SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672

APPOINTMENTS_QUEUE=appointments.queue
APPOINTMENTS_EXCHANGE=appointments.exchange

# Debug remoto JVM no Docker. Use localhost:5005 para appointment-service
# e localhost:5006 para notification-service.
APPOINTMENT_JAVA_TOOL_OPTIONS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005
NOTIFICATION_JAVA_TOOL_OPTIONS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5006

# Opcional. Deixe vazio para desativar o envio real via Gmail SMTP.
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_FROM=
PATIENT_REMINDER_FALLBACK_RECIPIENT=paciente@hospital.com

# Exemplo de configuracao do Gmail:
# GMAIL_USERNAME=sua-conta@gmail.com
# GMAIL_APP_PASSWORD=sua-senha-de-app
# GMAIL_FROM=sua-conta@gmail.com
# PATIENT_REMINDER_FALLBACK_RECIPIENT=paciente-real@example.com
